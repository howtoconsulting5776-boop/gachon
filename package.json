{
  "name": "gachon-educonsulting-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:setup": "node scripts/db-setup.cjs",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "next dev -p 3000 -H 127.0.0.1",
    "dev:ipv4": "next dev -p 3000 -H 127.0.0.1",
    "dev:turbo": "next dev -p 3000 -H 127.0.0.1 --turbo",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000 -H 127.0.0.1",
    "dev:clean:ipv4": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000 -H 127.0.0.1",
    "dev:any": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npx vercel@latest --prod",
    "deploy:preview": "npx vercel@latest",
    "images:lab-covers": "node scripts/fetch-lab-covers.mjs",
    "images:optimize": "node scripts/optimize-public-images.mjs",
    "github:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-to-github.ps1"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.62.8",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "@vercel/speed-insights": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "next-auth": "^4.24.14",
    "pretendard": "^1.3.9",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "resend": "^4.1.2",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
