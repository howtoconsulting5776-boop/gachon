# --- Supabase + Prisma (공식 권장 2줄) ---
# Dashboard → Connect to your project → ORM: Prisma → 표시되는 .env 를 그대로 복사하는 것이 가장 안전합니다.
#
# DATABASE_URL: Transaction pooler (6543) 또는 Session pooler (5432, pooler 호스트)
# DIRECT_URL:   Direct — db.<project-ref>.supabase.co:5432 (사용자명은 항상 postgres)
#
# 로컬 prisma db push 만 할 때: 아래처럼 둘 다 "직접 연결" URI로 통일해도 됩니다.
# DATABASE_URL="postgresql://postgres:비밀번호@db.xxxxx.supabase.co:5432/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres:비밀번호@db.xxxxx.supabase.co:5432/postgres?sslmode=require"
#
# --- P1000 Authentication failed 가 날 때 ---
# 1) Settings → Database → "Reset database password" 후 새 비밀번호로 URI 다시 만들기
# 2) 풀러(pooler.supabase.com) URI 를 쓰는 경우 사용자명이 postgres 가 아니라 postgres.<project-ref> 인지 확인
#    (대시보드 Connect 탭에 표시된 그대로 복사)
# 3) 비밀번호에 @ # % 등이 있으면 URL 인코딩 필요 (예: @ → %40)
# 4) 여전히 실패하면 DIRECT_URL 은 db.xxx.supabase.co 직접 연결, DATABASE_URL 만 풀러 문자열로 두기
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# 사이트 절대 URL (OG·sitemap·JSON-LD). 배포 시 Vercel 도메인 등으로 변경
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# NextAuth (관리자 /admin)
NEXTAUTH_SECRET="랜덤-긴-문자열으로-변경"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# DB 반영 — Supabase Connect 에서 복사한 URI에 [YOUR-PASSWORD] 가 있으면 아래 한 줄로 치환+push+seed
#   npm run db:setup -- "데이터베이스비밀번호"
# (이미 비밀번호를 수동으로 넣었다면: npm run db:push && npm run db:seed)

# --- Vercel 연결 (택 1) ---
#
# [권장] GitHub와 연동 — 코드 푸시만으로 자동 배포
#   1) https://vercel.com/new 접속 → GitHub 로그인
#   2) Import → 저장소 `howtoconsulting5776-boop/gachon` 선택
#   3) Framework: Next.js 자동 인식 → Environment Variables에 DATABASE_URL, NEXTAUTH_SECRET 등 복사
#   4) Deploy. 이후 `master` 푸시마다 프로덕션/프리뷰 빌드됨.
#
# [CLI] 로컬에서 프로젝트 연결 (.vercel 생성, gitignore 됨)
#   npm run vercel:login   # 브라우저에 표시된 코드 입력
#   npm run vercel:link    # 팀/프로젝트 선택 (또는 `npx vercel@latest link --project 프로젝트이름`)
#   npm run deploy         # 프로덕션 배포
#
# 폴더명이 한글 경로면 CLI가 프로젝트 이름을 잘못 추론할 수 있음 → link 시 프로젝트명을 명시하세요.
#
# 자동 배포 (택 1):
# (A) Vercel 대시보드에서 이 GitHub 저장소 연결 → main/master 푸시 시 자동 빌드·배포
# 첫 GitHub 업로드: `npm run github:login` → `npm run github:setup-git` → `npm run github:publish`
# (터미널에서 gh를 못 찾을 때: 위 npm 스크립트는 전체 경로로 gh를 실행합니다)
# (저장소 이름 바꿀 때: `$env:GITHUB_REPO_NAME = "원하는-리포-이름"` 후 같은 명령)
#
# (B) GitHub Actions: .github/workflows/deploy-vercel.yml 사용 시 저장소 Secrets 에 추가:
#     VERCEL_TOKEN — https://vercel.com/account/tokens
#     VERCEL_ORG_ID, VERCEL_PROJECT_ID — 로컬 `.vercel/project.json` (gitignore, link 후 확인)
#     Vercel 프로덕션 환경변수(DATABASE_URL 등)는 대시보드에 두면 `vercel pull` 빌드에 반영됩니다.

# --- 커스텀 도메인 배포 시 ---
# NEXT_PUBLIC_SITE_URL / NEXTAUTH_URL 을 동일한 프로덕션 URL(https://...)로 맞출 것

# --- Resend (뉴스레터 인증 메일) ---
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="에듀컨설팅 <news@your-verified-domain.com>"

# --- Upstash Redis (공개 API 분산 레이트 리밋, 선택) ---
# UPSTASH_REDIS_REST_URL="https://....upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."
