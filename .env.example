# --- Supabase + Prisma (공식 권장 2줄) ---
# Dashboard → Connect to your project → ORM: Prisma → 표시되는 .env 를 그대로 복사하는 것이 가장 안전합니다.
#
# DATABASE_URL: Transaction pooler (6543) 또는 Session pooler (5432, pooler 호스트)
# DIRECT_URL:   Direct — db.<project-ref>.supabase.co:5432 (사용자명은 항상 postgres)
#
# 로컬 prisma db push 만 할 때: 아래처럼 둘 다 "직접 연결" URI로 통일해도 됩니다.
# DATABASE_URL="postgresql://postgres:비밀번호@db.xxxxx.supabase.co:5432/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres:비밀번호@db.xxxxx.supabase.co:5432/postgres?sslmode=require"
#
# --- P1000 Authentication failed 가 날 때 ---
# 1) Settings → Database → "Reset database password" 후 새 비밀번호로 URI 다시 만들기
# 2) 풀러(pooler.supabase.com) URI 를 쓰는 경우 사용자명이 postgres 가 아니라 postgres.<project-ref> 인지 확인
#    (대시보드 Connect 탭에 표시된 그대로 복사)
# 3) 비밀번호에 @ # % 등이 있으면 URL 인코딩 필요 (예: @ → %40)
# 4) 여전히 실패하면 DIRECT_URL 은 db.xxx.supabase.co 직접 연결, DATABASE_URL 만 풀러 문자열로 두기
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# 사이트 절대 URL (OG·sitemap·JSON-LD). 배포 시 Vercel 도메인 등으로 변경
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# NextAuth (관리자 /admin)
NEXTAUTH_SECRET="랜덤-긴-문자열으로-변경"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# DB 반영 — Supabase Connect 에서 복사한 URI에 [YOUR-PASSWORD] 가 있으면 아래 한 줄로 치환+push+seed
#   npm run db:setup -- "데이터베이스비밀번호"
# (이미 비밀번호를 수동으로 넣었다면: npm run db:push && npm run db:seed)
